<div class="min-h-screen bg-base-100">

  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">
      <h1 class="text-4xl md:text-5xl font-bold">
        <%= @assembly.name %>
      </h1>
      <%= render "shared/instant_search" %>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-6 space-y-12">
    <section class="prose max-w-none">
      <h2>O divadle</h2>
      <p>
        <%= @assembly.production %>
      </p>
      <p>
        V kronike nájdete informácie o členoch, inscenáciách aj sprievodný
        multimediálny obsah.
      </p>
    </section>

    <section class="grid sm:grid-cols-3 gap-6">
      <%= link_to assembly_years_path(@assembly), class: "card bg-base-200 hover:bg-base-300 transition" do %>
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            Prehľad po rokoch
            <span class="badge badge-outline badge-primary badge-sm">
              <%= @assembly.member_of_assemblies.distinct.count(:year) %>
            </span>
          </h3>
          <p>Zobraziť členov a podujatia vo vybranom roku</p>
          <div class="card-actions justify-end">
            <span class="btn btn-link">Zobraziť →</span>
          </div>
        </div>
      <% end %>
      <%= link_to assembly_members_path(@assembly), class: "card bg-base-200 hover:bg-base-300 transition" do %>
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            Členovia
            <span class="badge badge-outline badge-primary badge-sm">
              <%= @assembly.members.count %>
            </span>
          </h3>
          <p>Zoznam hercov, režisérov a tvorcov súboru</p>
          <div class="card-actions justify-end">
            <span class="btn btn-link">Zobraziť →</span>
          </div>
        </div>
      <% end %>
      <%= link_to assembly_performances_path(@assembly), class: "card bg-base-200 hover:bg-base-300 transition" do %>
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            Podujatia
            <span class="badge badge-outline badge-secondary badge-sm">
              <%= @performances_count %>
            </span>
          </h3>
          <p>Predstavenia, premiéry a archív inscenácií</p>
          <div class="card-actions justify-end">
            <span class="btn btn-link">Zobraziť →</span>
          </div>
        </div>
      <% end %>
    </section>
  </main>

  <footer>
    <div class="max-w-4xl mx-auto px-6 py-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">

      <div class="text-sm opacity-70">
        Dáta spravuje:
        <a href="" class="link link-primary">
          Rastislav Letenaj
        </a>
      </div>

      <a href=""
         class="btn btn-sm btn-outline">
        Kontaktovať správcu
      </a>

    </div>
  </footer>

</div>
