<div class="min-h-screen bg-base-100">

  <section>
    <div class="max-w-4xl mx-auto px-6 pt-15 text-center space-y-8">
      <%= render "shared/instant_search" %>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-6 space-y-12">
    <section class="grid sm:grid-cols-3 gap-6">
      <%= link_to assembly_performances_path(@assembly), class: "card border border-base-300 bg-base-200 hover:bg-base-300 transition text-base-content" do %>
        <div class="card-body">
          <h3 class="card-title ">
            Časová os podujatí TD Bralen od roku 2025 až 1975
          </h3>
          <p class="flex justify-center pt-4">
            <span class="badge badge-outline badge-primary">
              <%= number_with_delimiter(@performances_count, delimiter: " ") %> podujatí
            </span>
          </p>
          <div class="card-actions justify-end">
            <span class="btn btn-link text-base-content">Zobraziť →</span>
          </div>
        </div>
      <% end %>
      <%= link_to assembly_years_path(@assembly), class: "card border border-base-300 bg-base-200 hover:bg-base-300 transition text-base-content" do %>
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            Prehľad podujatí po rokoch
          </h3>
          <p class="flex justify-center pt-4">
            <span class="badge badge-outline badge-primary">
              <%= @assembly.member_of_assemblies.distinct.count(:year) %> rokov
            </span>
          </p>
          <div class="card-actions justify-end">
            <span class="btn btn-link text-base-content">Zobraziť →</span>
          </div>
        </div>
      <% end %>
      <%= link_to assembly_members_path(@assembly), class: "card border border-base-300 bg-base-200 hover:bg-base-300 transition text-base-content" do %>
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            Zoznam členov súboru a prípravných skupín TD Bralen
          </h3>
          <p class="flex justify-center pt-4">
            <span class="badge badge-outline badge-primary">
              <%= number_with_delimiter(@assembly.members.count, delimiter: " ") %> členov
            </span>
          </p>
          <div class="card-actions justify-end">
            <span class="btn btn-link text-base-content">Zobraziť →</span>
          </div>
        </div>
      <% end %>
    </section>
     <section class="prose max-w-none">
      <h2>O divadle</h2>
      <p>
        <%= @assembly.production %>
      </p>
      <p>
        V kronike nájdete informácie o členoch, inscenáciách aj sprievodný
        multimediálny obsah.
      </p>
    </section>
  </main>

  <footer>
    <div class="max-w-4xl mx-auto px-6 pt-15 py-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
      <div></div>
      <div class="text-sm opacity-70">
        Dáta spravuje:
        <b>Rastislav Letenaj</b>
      </div>
      <div></div>
    </div>
  </footer>

</div>
