<% content_for :title, "Set new password — Kronika" %>

<div class="flex justify-center items-center py-12 px-4">
  <div class="card bg-base-200 w-full max-w-md shadow-lg">
    <div class="card-body gap-4">
      <h1 class="card-title text-2xl font-bold">Set new password</h1>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div class="form-control">
          <%= f.label :password, "New password", class: "label label-text" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-base-content/60 -mt-1 ml-1"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
          <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-3">
          <%= f.label :password_confirmation, "Confirm new password", class: "label label-text" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <div class="mt-6">
          <%= f.submit "Change password", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <p class="text-center text-sm mt-2">
        <%= link_to "Back to sign in", new_user_session_path, class: "link link-hover" %>
      </p>
    </div>
  </div>
</div>
