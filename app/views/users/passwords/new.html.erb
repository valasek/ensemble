<% content_for :title, "Reset password — Kronika" %>

<div class="flex justify-center items-center py-12 px-4">
  <div class="card bg-base-200 w-full max-w-md shadow-lg">
    <div class="card-body gap-4">
      <h1 class="card-title text-2xl font-bold">Forgot your password?</h1>
      <p class="text-sm text-base-content/70">
        Enter your email and we'll send you a link to reset your password.
      </p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <div class="form-control">
          <%= f.label :email, class: "label label-text" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "input input-bordered w-full" %>
        </div>

        <div class="mt-6">
          <%= f.submit "Send reset instructions", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <p class="text-center text-sm mt-2">
        <%= link_to "Back to sign in", new_user_session_path, class: "link link-hover" %>
      </p>
    </div>
  </div>
</div>
