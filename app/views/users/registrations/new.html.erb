<% content_for :title, "Sign up free — Kronika" %>
<%# Load Cloudflare Turnstile script only on this page %>
<% content_for :head do %>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<% end %>

<div class="flex justify-center items-center py-12 px-4">
  <div class="card bg-base-200 w-full max-w-md shadow-lg">
    <div class="card-body gap-4">
      <h1 class="card-title text-2xl font-bold">Create your account</h1>

      <%# Google SSO %>
      <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            data: { turbo: false },
            class: "btn btn-outline w-full gap-2 font-medium" do %>
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Sign up with Google
      <% end %>

      <div class="divider text-xs text-base-content/50">or sign up with email</div>

      <%# Email + password registration form %>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.hidden_field :authenticity_token, value: form_authenticity_token %>

        <div class="form-control">
          <%= f.label :email, class: "label label-text" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-3">
          <%= f.label :password, class: "label label-text" do %>
            Password
            <% if @minimum_password_length %>
              <span class="label-text-alt text-base-content/60">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
          <% end %>
          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-3">
          <%= f.label :password_confirmation, "Confirm password", class: "label label-text" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <%# Cloudflare Turnstile widget %>
        <div class="mt-4 flex justify-center">
          <div class="cf-turnstile"
               data-sitekey="<%= Rails.application.credentials.dig(:cloudflare, :turnstile_site_key) %>"
               data-theme="auto"></div>
        </div>

        <div class="mt-6">
          <%= f.submit "Sign up free", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <p class="text-center text-sm mt-2">
        Already have an account?
        <%= link_to "Sign in", new_user_session_path, class: "link link-primary font-medium" %>
      </p>
    </div>
  </div>
</div>
