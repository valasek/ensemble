<div class="min-h-screen bg-base-100">

  <!-- HERO -->
  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">

      <!-- Name -->
      <h1 class="text-4xl md:text-5xl font-bold">
        Predstavenia zájazdy a podujatia
      </h1>

      <%= render "shared/instant_search" %>

      <%= form_with url: assembly_performances_path(@assembly), method: :get, class: "flex justify-center items-end gap-3 flex-wrap" do %>
        <div class="form-control w-full max-w-sm">
          <label class="label" for="category_id">
            <span class="label-text mb-4">Filter podľa kategórie</span>
          </label>
          <%= select_tag :category_id,
                         options_from_collection_for_select(@category_options, :id, :name, @selected_category_id),
                         include_blank: "Všetky kategórie",
                         class: "select select-bordered w-full",
                         id: "category_id" %>
        </div>
        <%= submit_tag "Filtrovať", class: "btn btn-primary" %>
        <% if @selected_category_id.present? %>
          <%= link_to "Zrušiť filter", assembly_performances_path(@assembly), class: "btn btn-ghost" %>
        <% end %>
      <% end %>

      <div class="badge badge-primary badge-outline badge-lg">
        <%= number_with_delimiter(@performances.total_count, delimiter: " ") %> podujatí
      </div>

    </div>
  </section>

  <%= turbo_frame_tag "performances-table" do %>
  <section class="space-y-6 p-4">

    <%= render "performances/performances_list", performances: @performances, assembly: @assembly %>

    <%= paginate @performances, params: { category_id: @selected_category_id.presence } %>
  </section>
  <% end %>


</div>
