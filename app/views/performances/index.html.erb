<div class="min-h-screen bg-base-100">

  <!-- HERO -->
  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">

      <!-- Name -->
      <h1 class="text-4xl md:text-5xl font-bold">
        Podujatia
      </h1>

      <%= render "shared/instant_search" %>

      <div class="badge badge-primary badge-outline badge-lg">
        <%= @assembly.performances.count %> podujatí
      </div>

    </div>
  </section>

  <%= turbo_frame_tag "performances-table" do %>
  <section class="space-y-6 p-4">

    <!-- MOBILE: stacked cards -->
    <div class="md:hidden space-y-3">
      <% @performances.each do |performance| %>
        <a href="<%= assembly_performance_path(@assembly, performance) %>"
           class="block card bg-base-200 shadow-sm hover:shadow transition-shadow">
          <div class="card-body p-4 gap-1">
            <h2 class="card-title text-base"><%= performance.name %></h2>
            <p class="text-sm text-base-content/60">
              <% if performance.end_date.present? %>
                <%= performance.date.strftime("%d. %m. %Y") %> &ndash; <%= performance.end_date.strftime("%d. %m. %Y") %>
              <% else %>
                <%= performance.date.strftime("%d. %m. %Y") %>
              <% end %>
              <% if performance.location.present? %>
                &middot; <%= performance.location %>
              <% end %>
            </p>
            <% if performance.description.present? %>
              <div class="text-sm mt-1 line-clamp-2 text-base-content/80"><%= performance.description %></div>
            <% end %>
          </div>
        </a>
      <% end %>
    </div>

    <!-- DESKTOP: table -->
    <div class="hidden md:block overflow-x-auto rounded-box">
      <table class="table table-zebra w-full">
        <colgroup>
          <col class="w-1/5">
          <col class="w-1/6">
          <col class="w-1/6">
          <col class="w-5/12">
        </colgroup>
        <thead>
          <tr>
            <th>Názov</th>
            <th>Dátum</th>
            <th>Miesto</th>
            <th>Popis</th>
          </tr>
        </thead>
        <tbody>
          <% @performances.each do |performance| %>
            <tr class="hover:bg-base-300 cursor-pointer"
                data-controller="row-link"
                data-action="click->row-link#navigate"
                data-row-link-url-value="<%= assembly_performance_path(@assembly, performance) %>">
              <td class="font-medium">
                <b><%= performance.name %></b>
              </td>
              <td class="whitespace-nowrap">
                <% if performance.end_date.present? %>
                  <%= performance.date.strftime("%d. %m. %Y") %> &ndash; <%= performance.end_date.strftime("%d. %m. %Y") %>
                <% else %>
                  <%= performance.date.strftime("%d. %m. %Y") %>
                <% end %>
              </td>
              <td>
                <%= performance.location %>
              </td>
              <td>
                <div class="max-h-[4.5rem] overflow-hidden text-sm
                            [mask-image:linear-gradient(to_bottom,black_55%,transparent_100%)]
                            [-webkit-mask-image:linear-gradient(to_bottom,black_55%,transparent_100%)]">
                  <%= performance.description %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= paginate @performances %>
  </section>
  <% end %>


</div>
