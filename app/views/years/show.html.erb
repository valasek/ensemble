<div class="min-h-screen bg-base-100">

  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">
      <h1 class="text-4xl md:text-5xl font-bold">
        Rok <%= @year %>
      </h1>
      <%= link_to "← Späť na prehľad rokov", assembly_years_path(@assembly), class: "btn btn-ghost btn-sm" %>
    </div>
  </section>

  <main class="px-6 space-y-12 pb-16">

    <% if @assembly_year&.description&.present? %>
      <section data-controller="expand">
        <div class="relative">
          <div data-expand-target="content"
               class="prose prose-lg max-w-none overflow-hidden"
               style="max-height: 280px;">
            <%= @assembly_year.description %>
          </div>
          <div data-expand-target="overlay"
               class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-base-100 to-transparent pointer-events-none rounded-b">
          </div>
        </div>
        <div class="flex justify-center mt-2 gap-4">
          <button data-expand-target="expandBtn"
                  data-action="click->expand#expand"
                  class="btn btn-ghost btn-sm text-primary gap-1">
            Čítať viac
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
          <button data-expand-target="collapseBtn"
                  data-action="click->expand#collapse"
                  class="btn btn-ghost btn-sm text-primary gap-1 hidden">
            Zobraziť menej
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 rotate-180">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </section>
    <% end %>

    <% if @featured_performances.any? %>
      <section>
        <h2 class="text-2xl font-semibold mb-4">Najdôležitejšie podujatia roku</h2>
        <%= render "performances/performances_list", performances: @featured_performances, assembly: @assembly %>
      </section>
    <% end %>

    <section>
      <details>
        <summary class="text-2xl font-semibold mb-4 cursor-pointer list-none flex items-center gap-2 group">
          Členovia
          <span class="badge badge-outline badge-primary badge-sm ml-2"><%= @members.size %></span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 ml-auto text-primary transition-transform duration-300 group-open:rotate-180">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </summary>
        <% if @members.any? %>
          <div class="mt-4">
            <%= render "members/members_table", members: @members, assembly: @assembly %>
          </div>
        <% else %>
          <p class="opacity-50 mt-4">Žiadni členovia pre tento rok.</p>
        <% end %>
      </details>
    </section>

    <section>
      <details>
        <summary class="text-2xl font-semibold mb-4 cursor-pointer list-none flex items-center gap-2 group">
          Podujatia
          <span class="badge badge-outline badge-secondary badge-sm ml-2"><%= @performances.size %></span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 ml-auto text-secondary transition-transform duration-300 group-open:rotate-180">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </summary>
        <% if @performances.any? %>
          <% sk_months = %w[Január Február Marec Apríl Máj Jún Júl August September Október November December] %>
          <% @performances.group_by { |p| p.date.month }.each_with_index do |(month_num, month_performances), idx| %>
            <div class="flex items-center gap-4 <%= idx == 0 ? 'mt-6' : 'mt-12' %> mb-4">
              <div class="flex-1 h-px bg-base-300"></div>
              <h3 class="text-3xl font-extrabold text-primary whitespace-nowrap"><%= sk_months[month_num - 1] %></h3>
              <div class="flex-1 h-px bg-base-300"></div>
            </div>

            <%= render "performances/performances_list", performances: month_performances, assembly: @assembly %>
          <% end %>
        <% else %>
          <p class="opacity-50 mt-4">Žiadne podujatia pre tento rok.</p>
        <% end %>
      </details>
    </section>

  </main>

</div>
