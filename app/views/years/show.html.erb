<div class="min-h-screen bg-base-100">

  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">
      <h1 class="text-4xl md:text-5xl font-bold">
        Rok <%= @year %>
      </h1>
      <p class="text-lg opacity-70"><%= @assembly.name %></p>
      <%= link_to "← Späť na prehľad rokov", assembly_years_path(@assembly), class: "btn btn-ghost btn-sm" %>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-6 space-y-12 pb-16">

    <section>
      <h2 class="text-2xl font-semibold mb-4">
        Členovia
        <span class="badge badge-outline badge-primary badge-sm ml-2"><%= @members.size %></span>
      </h2>
      <% if @members.any? %>
        <div class="overflow-x-auto rounded-box">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>Meno</th>
              </tr>
            </thead>
            <tbody>
              <% @members.each do |member| %>
                <tr class="hover:bg-base-300">
                  <td class="font-medium">
                    <%= link_to member.name, assembly_member_path(@assembly, member), class: "link link-primary" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="opacity-50">Žiadni členovia pre tento rok.</p>
      <% end %>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">
        Podujatia
        <span class="badge badge-outline badge-secondary badge-sm ml-2"><%= @performances.size %></span>
      </h2>
      <% if @performances.any? %>
        <div class="overflow-x-auto rounded-box">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>Názov</th>
                <th>Dátum</th>
                <th>Miesto</th>
              </tr>
            </thead>
            <tbody>
              <% @performances.each do |performance| %>
                <tr class="hover:bg-base-300">
                  <td class="font-medium">
                    <%= link_to performance.name, assembly_performance_path(@assembly, performance), class: "link link-primary" %>
                  </td>
                  <td><%= performance.date.strftime("%d. %m. %Y") %></td>
                  <td><%= performance.location %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="opacity-50">Žiadne podujatia pre tento rok.</p>
      <% end %>
    </section>

  </main>

</div>
