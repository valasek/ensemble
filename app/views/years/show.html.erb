<div class="min-h-screen bg-base-100">

  <section>
    <div class="max-w-4xl mx-auto px-6 py-15 text-center space-y-8">
      <h1 class="text-4xl md:text-5xl font-bold">
        Rok <%= @year %>
      </h1>
      <p class="text-lg opacity-70"><%= @assembly.name %></p>
      <%= link_to "← Späť na prehľad rokov", assembly_years_path(@assembly), class: "btn btn-ghost btn-sm" %>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-6 pb-16">
    <div class="alert alert-info">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="h-6 w-6 shrink-0 stroke-current">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>ToDo: obsah pre rok <%= @year %></span>
    </div>
  </main>

</div>
