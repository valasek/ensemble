<nav class="navbar bg-base-200 shadow-sm">
  <%# Left: Assembly name as brand logo %>
  <div class="navbar-start">
    <% if defined?(@assembly) && @assembly.present? %>
      <%= link_to root_path, class: "btn btn-ghost flex items-center gap-2 px-3 group" do %>
        <%= image_tag "favicon.ico", class: "w-7 h-7 rounded-md", alt: @assembly.name %>
        <span class="text-lg font-bold tracking-tight group-hover:text-primary transition-colors"><%= @assembly.name %></span>
      <% end %>
    <% else %>
      <%= link_to root_path, class: "btn btn-ghost flex items-center gap-2 px-3" do %>
        <%= image_tag "favicon.ico", class: "w-7 h-7 rounded-md", alt: "Kronika" %>
        <span class="text-lg font-bold tracking-tight">Kronika</span>
      <% end %>
    <% end %>
  </div>

  <%# Center: empty %>
  <div class="navbar-center"></div>

  <%# Right: auth links + mobile hamburger %>
  <div class="navbar-end gap-2" data-controller="theme">
    <label class="hidden md:flex items-center gap-2 text-sm">
      <span class="opacity-70">Téma</span>
      <select class="select select-sm select-bordered text-base-content" data-theme-target="select" data-action="change->theme#change" aria-label="Zmeniť tému">
        <option value="auto">Auto</option>
        <option value="light">Light</option>
        <option value="dark">Dark</option>
      </select>
    </label>

    <%# Desktop %>
    <div class="hidden lg:flex items-center gap-2">
      <% if user_signed_in? %>
        <%= link_to "Administration", "/admin", class: "btn btn-ghost btn-sm" %>
        <%= link_to "Sign out", destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "btn btn-ghost btn-sm" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "Sign up free", new_user_registration_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>

    <%# Mobile: hamburger dropdown %>
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 text-base-content rounded-box z-10 mt-3 w-48 p-2 shadow">
        <li class="menu-title">Téma</li>
        <li>
          <select class="select select-sm select-bordered text-base-content mx-2 my-1" data-theme-target="select" data-action="change->theme#change" aria-label="Zmeniť tému">
            <option value="auto">Auto</option>
            <option value="light">Light</option>
            <option value="dark">Dark</option>
          </select>
        </li>
        <li class="menu-title">Navigácia</li>
        <li><%= link_to "Home", root_path, class: "text-base-content" %></li>
        <% if user_signed_in? %>
          <li><%= link_to "Administration", "/admin", class: "text-base-content" %></li>
          <li>
            <%= link_to "Sign out", destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "text-base-content" %>
          </li>
        <% else %>
          <li><%= link_to "Sign in", new_user_session_path, class: "text-base-content" %></li>
          <li><%= link_to "Sign up free", new_user_registration_path, class: "text-base-content" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
