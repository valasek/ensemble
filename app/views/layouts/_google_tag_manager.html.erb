<% gtm_id = Rails.application.credentials.gtm_id %>
<% if Rails.env.production? && gtm_id.present? %>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gtm_id %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', '<%= gtm_id %>');
  </script>
<% end %>
